<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title><%= typeof title !== 'undefined' ? title + ' | ' : '' %>Platformă meșteri</title>
<% if (typeof description !== 'undefined' && description) { %>
<meta name="description" content="<%= description %>">
<% } %>
<% if (typeof robots !== 'undefined' && robots) { %>
<meta name="robots" content="<%= robots %>">
<% } %>
<link rel="canonical" href="<%= typeof canonical !== 'undefined' ? canonical : baseUrl + (typeof path === 'undefined' ? '' : path) %>">
<meta property="og:title" content="<%= typeof title !== 'undefined' ? title : 'Platformă meșteri' %>">
<meta property="og:type" content="website">
<meta property="og:url" content="<%= typeof canonical !== 'undefined' ? canonical : baseUrl %>">
<% if (typeof description !== 'undefined' && description) { %>
<meta property="og:description" content="<%= description %>">
<% } %>
<link rel="stylesheet" href="/css/fonts.css">
<link rel="stylesheet" href="/css/main.css">
