<h1>Conversație</h1>
<div class="card" id="msg-box">
  <% (messages || []).forEach(m => { %>
    <p><strong><%= m.sender_name %>:</strong> <%= m.message_body %> <span class="muted"><%= m.created_at %></span></p>
  <% }); %>
</div>
<form method="post" action="/mesaje/<%= convId %>" class="card">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <label>Mesaj</label>
  <textarea name="message_body" required></textarea>
  <button type="submit" class="btn">Trimite</button>
</form>
<script src="/js/poll.js" defer></script>
<script>window.__convId = <%= convId %>;</script>
